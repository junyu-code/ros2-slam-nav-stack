          <material>
            <ambient>0.42 0.43 0.42 1</ambient>
            <diffuse>0.50 0.52 0.50 1</diffuse>
          </material>
        </visual>
      </link>
      <pose>0 0 -0.02 0 0 0</pose>
    </model>

