              <radius>0.32</radius>
              <length>1.1</length>
            </cylinder>
          </geometry>
          <material>
            <ambient>0.82 0.18 0.18 1</ambient>
            <diffuse>0.95 0.26 0.22 1</diffuse>
            <specular>0.2 0.08 0.06 1</specular>
          </material>
        </visual>
      </link>
      <plugin name="dynamic_obstacle_plugin" filename="libdynamic_obstacle_plugin.so">
        <robot_model>mobile_robot</robot_model>
        <start_x>2.2</start_x>
        <start_y>-2.6</start_y>
        <end_x>2.2</end_x>
        <end_y>2.6</end_y>
        <height>0.55</height>
        <speed>0.35</speed>
        <pause_time>0.8</pause_time>
        <yield_radius>1.20</yield_radius>
        <yield_resume_radius>1.55</yield_resume_radius>
      </plugin>
    </model>

    <model name="fast_moving_obstacle">
