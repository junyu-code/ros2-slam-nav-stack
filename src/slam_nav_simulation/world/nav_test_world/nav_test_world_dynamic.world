      </link>
      <pose>-0.3 4.1 0.11 0 0.14 0</pose>
    </model>

    <model name="moving_obstacle">
      <static>false</static>
      <pose>2.2 -2.6 0.55 0 0 1.5708</pose>
      <link name="link">
        <gravity>false</gravity>
        <kinematic>true</kinematic>
        <collision name="collision">
          <geometry>
            <cylinder>
              <radius>0.32</radius>
              <length>1.1</length>
            </cylinder>
          </geometry>
          <surface>
            <friction>
              <ode>
                <mu>10</mu>
                <mu2>10</mu2>
              </ode>
