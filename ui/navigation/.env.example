VITE_CAMERA_TOPIC=/nav_camera/color/image_raw
VITE_MAP_TOPIC=/map
# VITE_NAV_DEPTH_WS_URL=ws://127.0.0.1:8765/ws/nav/depth
# VITE_PIPER_RGB_WS_URL=ws://127.0.0.1:8765/ws/piper/rgb
# VITE_PIPER_DEPTH_WS_URL=ws://127.0.0.1:8765/ws/piper/depth

SLAM_NAV_CAMERA_TOPIC=/nav_camera/color/image_raw
SLAM_NAV_DEPTH_TOPIC=/nav_camera/depth/image_raw
SLAM_NAV_PIPER_COLOR_TOPIC=/piper/arm_camera/color/image_raw
SLAM_NAV_PIPER_DEPTH_TOPIC=/piper/arm_camera/depth/image_raw
SLAM_NAV_NAVIGATION_READY_TOPIC=/navigation_ready
SLAM_NAV_UI_HOST=127.0.0.1
SLAM_NAV_UI_PORT=8765
SLAM_NAV_UI_DISABLE_CAMERA=0
SLAM_NAV_UI_DISABLE_PIPER_CAMERA=0
SLAM_NAV_UI_REBUILD=0
SLAM_NAV_PIPER_CAMERA_QUALITY=80
SLAM_NAV_PIPER_CAMERA_MAX_FPS=10
SLAM_NAV_PIPER_DEPTH_MIN_M=0.15
SLAM_NAV_PIPER_DEPTH_MAX_M=2.5
SLAM_NAV_DEPTH_MIN_M=0.25
SLAM_NAV_DEPTH_MAX_M=5.0
SLAM_NAV_MAP_TOPIC=/map
SLAM_NAV_GLOBAL_COSTMAP_TOPIC=/global_costmap/costmap
SLAM_NAV_LOCAL_COSTMAP_TOPIC=/local_costmap/costmap
SLAM_NAV_GLOBAL_PLAN_TOPIC=/plan
SLAM_NAV_LOCAL_PLAN_TOPIC=/local_plan
SLAM_NAV_MAP_FRAME=map
SLAM_NAV_ROBOT_FRAMES=base_footprint,base_link

# 旧部署兼容变量；仅在对应 SLAM_NAV_UI_* 未设置时生效。
# SLAM_NAV_NAV_UI_HOST=127.0.0.1
# SLAM_NAV_NAV_UI_PORT=8765
